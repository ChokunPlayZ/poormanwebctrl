{
  "version": 1,
  "web_server": { "provider": "openlitespeed" },
  "database": {
    "provider": "mariadb",
    "role": "primary",
    "replication": {
      "user": "replicator",
      "password_env": "POORMAN_REPLICATION_PASSWORD",
      "allowed_cidr": "127.0.0.1/32",
      "node_id": 1
    },
    "local_replica": {
      "port": 3307,
      "data_dir": "/var/lib/mysql/poorman-replica-3307",
      "node_id": 2
    }
  },
  "firewall": { "enabled": true }
}
